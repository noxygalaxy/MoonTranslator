{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MoonTranslator",
  "version": "0.1.0",
  "identifier": "dev.noxygalaxy.moontranslator",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MoonTranslator",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "both",
        "languages": ["English"],
        "startMenuFolder": "MoonTranslator"
      }
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://api.github.com/repos/noxygalaxy/MoonTranslator/releases/latest"
      ]
    }
  }
}
