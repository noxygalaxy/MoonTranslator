{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MoonTranslator",
  "version": "0.1.3",
  "identifier": "dev.noxygalaxy.moontranslator",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MoonTranslator",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": ["main", "popup"],
          "permissions": [
            "core:default",
            "core:window:allow-start-dragging",
            "core:window:allow-set-size",
            "store:default",
            "store:allow-load",
            "store:allow-save",
            "store:allow-set",
            "store:allow-get",
            "clipboard-manager:default",
            "clipboard-manager:allow-read-text",
            "clipboard-manager:allow-write-text",
            "shell:allow-open"
          ]
        },
        {
          "identifier": "shell-urls",
          "windows": ["main", "popup"],
          "permissions": [
            {
              "identifier": "shell:allow-open",
              "allow": [{ "url": "https://**" }, { "url": "http://**" }]
            }
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "both",
        "languages": [
          "English"
        ],
        "startMenuFolder": "MoonTranslator"
      }
    }
  }
}
